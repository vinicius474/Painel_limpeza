# =============================================================================
# VARIÁVEIS DE AMBIENTE — Painel de Limpeza
# Copie este arquivo para .env e preencha os valores ANTES de iniciar.
# NUNCA versione o .env em repositórios públicos.
# =============================================================================

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── JWT ───────────────────────────────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=substitua-por-string-aleatoria-de-no-minimo-64-caracteres
JWT_EXPIRES_IN=8h

# ── Credenciais de acesso ──────────────────────────────────────────────────────
# Gere o hash com: node scripts/hash-password.js SUA_SENHA
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2b$12$SUBSTITUA_PELO_HASH_GERADO_COM_O_SCRIPT
# Perfil somente leitura (opcional — remova as linhas para desativar)
VIEWER_USERNAME=viewer
VIEWER_PASSWORD_HASH=$2b$12$SUBSTITUA_PELO_HASH_GERADO_COM_O_SCRIPT

# ── Webhook N8N ───────────────────────────────────────────────────────────────
WEBHOOK_URL=https://seu-n8n.com/webhook/painel-limpeza

# Chave de API para o webhook (opcional — configure também no N8N)
WEBHOOK_API_KEY=

# ── Banco de dados MySQL ──────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=suporte_ativos
DB_USER=seu_usuario
DB_PASSWORD=sua_senha

# ── CORS (produção) ───────────────────────────────────────────────────────────
# Origens permitidas, separadas por vírgula
ALLOWED_ORIGINS=https://painel.rt-automations.com.br

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# Intervalo de atualização automática em ms (padrão: 3600000 = 1 hora)
VITE_REFRESH_INTERVAL=3600000
